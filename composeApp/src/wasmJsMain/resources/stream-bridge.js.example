// Template for stream-bridge.js
// Instructions: Copy this file to stream-bridge.js.
// This file contains no secrets — all credentials (API key, user token) are passed
// in at runtime from Kotlin via connectUser(apiKey, userToken, userId).
// It is gitignored as a precaution in case future changes introduce sensitive config.

/**
 * Bridge for Stream Chat SDK for Kotlin/Wasm
 */
window.wdwStreamBridge = {
    initialized: false,
    client: null,
    currentChannel: null,
    messageCallbacks: [],

    /**
     * Connects a user to Stream Chat
     */
    connectUser: async function(apiKey, userToken, userId) {
        console.log("StreamBridge: connectUser called for:", userId);
        try {
            if (!window.StreamChat) {
                console.log("StreamBridge: Downloading Stream SDK...");
                const module = await import("https://cdn.jsdelivr.net/npm/stream-chat/+esm");
                window.StreamChat = module.StreamChat;
            }

            // Skip if already connected with the same user
            if (this.initialized && this.client && this.client.userID === userId) {
                console.log("StreamBridge: Already connected as", userId, "— skipping reconnect");
                return;
            }

            if (this.initialized && this.client) {
                console.log("StreamBridge: Disconnecting existing client...");
                await this.client.disconnectUser();
            }

            this.client = window.StreamChat.getInstance(apiKey);
            
            console.log("StreamBridge: Connecting user...");
            await this.client.connectUser(
                { id: userId },
                userToken
            );

            // Set up listener for new messages and reactions
            this.client.on((event) => {
                const mappedEvent = {
                    type: event.type,
                    userId: event.user?.id || '',
                    userName: event.user?.name || event.user?.id || '',
                    channelId: event.cid ? event.cid.replace('messaging:', '') : ''
                };

                if (event.type === 'message.new' || event.type === 'message.deleted' || event.type === 'message.updated') {
                    console.log("StreamBridge: Message event:", event.type);
                    this.messageCallbacks.forEach(cb => cb(mappedEvent));
                } else if (event.type === 'message.read') {
                    console.log("StreamBridge: Read event:", event.type);
                    this.messageCallbacks.forEach(cb => cb(mappedEvent));
                } else if (event.type === 'reaction.new' || event.type === 'reaction.deleted' || event.type === 'reaction.updated') {
                    console.log("StreamBridge: Reaction event:", event.type);
                    this.messageCallbacks.forEach(cb => cb(mappedEvent));
                } else if (event.type === 'typing.start' || event.type === 'typing.stop') {
                    this.messageCallbacks.forEach(cb => cb(mappedEvent));
                }
            });

            this.initialized = true;
            console.log("StreamBridge: User connected successfully");
        } catch (error) {
            console.error("StreamBridge: Error in connectUser:", error);
            throw error;
        }
    },

    /**
     * Maps a Stream message object to a simplified format
     */
    _mapMessage: function(m, channel) {
        // Build reactions summary: { "like": { count: 2, own: true }, "love": { count: 1, own: false } }
        const reactions = {};
        if (m.reaction_counts) {
            for (const [type, count] of Object.entries(m.reaction_counts)) {
                const ownReaction = m.own_reactions?.some(r => r.type === type) || false;
                reactions[type] = { count, own: ownReaction };
            }
        }

        const isMessageDeleted = m.type === 'deleted';
        let readStatus = "sent";
        
        if (channel && channel.state && channel.state.read) {
            const msgTime = new Date(m.created_at).getTime();
            let isReadByOther = false;
            for (const [userId, readState] of Object.entries(channel.state.read)) {
                if (userId !== m.user?.id) {
                    const readTime = new Date(readState.last_read).getTime();
                    if (readTime >= msgTime) {
                        isReadByOther = true;
                        break;
                    }
                }
            }
            readStatus = isReadByOther ? "read" : "delivered";
        }
        
        return {
            id: m.id,
            text: isMessageDeleted ? 'This message was deleted.' : (m.text || ''),
            userId: m.user?.id || '',
            userName: m.user?.name || m.user?.id || '',
            userImage: m.user?.image || '',
            createdAt: new Date(m.created_at).toISOString(),
            parentId: m.parent_id || '',
            replyCount: m.reply_count || 0,
            quotedText: m.quoted_message?.text || '',
            quotedUserName: m.quoted_message?.user?.name || m.quoted_message?.user?.id || '',
            reactions: JSON.stringify(reactions),
            attachments: JSON.stringify(m.attachments || []),
            isDeleted: isMessageDeleted,
            readStatus: readStatus,
            isMentioned: Array.isArray(m.mentioned_users) && m.mentioned_users.some(u => u.id === this.client.userID),
            userOnline: m.user?.online || false,
            pinned: !!m.pinned_at
        };
    },

    /**
     * Helper to extract mentioned users from text by matching @username
     * against members in the channel.
     */
    _extractMentions: function(text, channel) {
        if (!text || !channel || !channel.state.members) return [];
        
        // Find all strings starting with @ followed by word characters
        const mentionMatches = text.match(/@(\w+[\w\s]*\w+|\w+)/g);
        if (!mentionMatches) return [];

        const mentionedUserIds = [];
        const members = Object.values(channel.state.members);

        mentionMatches.forEach(match => {
            const username = match.substring(1).toLowerCase().trim();
            // Look for a member with this name or id
            const member = members.find(m => {
                if (!m.user) return false;
                const nameMatch = m.user.name && m.user.name.toLowerCase() === username;
                const idMatch = m.user.id.toLowerCase() === username;
                return nameMatch || idMatch;
            });

            if (member && !mentionedUserIds.includes(member.user_id)) {
                mentionedUserIds.push(member.user_id);
            }
        });

        return mentionedUserIds;
    },

    /**
     * Helper to map a raw JS channel object to our Kotlin-friendly format
     */
    _mapChannelData: function(c) {
        let channelName = c.data.name;
        let isDM = false;

        // Determine if it's a direct message (1-on-1)
        const members = Object.values(c.state.members || {});
        if (!channelName && members.length === 2) {
            isDM = true;
            // Find the other user
            const otherMember = members.find(m => m.user_id !== this.client.userID);
            if (otherMember && otherMember.user) {
                channelName = otherMember.user.name || otherMember.user.id;
            }
        }

        if (!channelName) {
            channelName = isDM ? 'Direct Message' : 'Chat';
        }

        // Get channel image: for DMs use the other member's avatar, for groups use channel image
        let channelImage = '';
        if (isDM) {
            const otherMember = members.find(m => m.user_id !== this.client.userID);
            if (otherMember && otherMember.user && otherMember.user.image) {
                channelImage = otherMember.user.image;
            }
        } else {
            channelImage = c.data.image || '';
        }

        // Online status: for DMs, check if the other member is online
        let otherUserOnline = false;
        let otherUserId = '';
        if (isDM) {
            const otherMember = members.find(m => m.user_id !== this.client.userID);
            if (otherMember && otherMember.user) {
                otherUserOnline = otherMember.user.online || false;
                otherUserId = otherMember.user_id || '';
            }
        }

        return {
            id: c.id,
            cid: c.cid,
            name: channelName,
            image: channelImage,
            lastMessage: c.state.messages[c.state.messages.length - 1]?.text || '',
            lastMessageUserId: c.state.messages[c.state.messages.length - 1]?.user?.id || '',
            unreadCount: c.countUnread(),
            isDirectMessage: isDM,
            otherUserOnline: otherUserOnline,
            otherUserId: otherUserId
        };
    },

    /**
     * Returns a list of channels for the current user
     */
    queryChannels: async function() {
        if (!this.client) return [];
        try {
            const filter = { type: 'messaging', members: { $in: [this.client.userID] } };
            const sort = [{ last_message_at: -1 }];
            const channels = await this.client.queryChannels(filter, sort, {
                watch: true,
                presence: true,
                limit: 10
            });
            
            return channels.map(c => this._mapChannelData(c));
        } catch (error) {
            console.error("StreamBridge: Error querying channels:", error);
            return [];
        }
    },

    /**
     * Gets message history for a specific channel
     */
    getMessages: async function(channelId) {
        if (!this.client) return [];
        try {
            // Use currentChannel if it matches, to ensure we read the same state
            let channel;
            if (this.currentChannel && this.currentChannel.id === channelId) {
                channel = this.currentChannel;
                // Query to refresh state from server
                await channel.query({ messages: { limit: 50 } });
            } else {
                channel = this.client.channel('messaging', channelId);
                await channel.watch();
            }
            
            // Store as current channel so addReaction/removeReaction can use it
            this.currentChannel = channel;
            
            const mapped = channel.state.messages.map(m => {
                const msg = this._mapMessage(m, channel);
                // Debug: log reaction data for messages that have reactions
                if (m.reaction_counts && Object.keys(m.reaction_counts).length > 0) {
                    console.log("StreamBridge: Message", m.id.substring(0, 10), "reactions:", 
                        JSON.stringify(m.reaction_counts), "own:", 
                        m.own_reactions?.map(r => r.type));
                }
                return msg;
            });
            return mapped;
        } catch (error) {
            console.error("StreamBridge: Error getting messages:", error);
            return [];
        }
    },

    /**
     * Sends a message to a channel
     */
    sendMessage: async function(channelId, text) {
        if (!this.client) return null;
        try {
            const channel = this.client.channel('messaging', channelId);
            const mentionedUsers = this._extractMentions(text, channel);
            
            const payload = { text };
            if (mentionedUsers.length > 0) {
                payload.mentioned_users = mentionedUsers;
            }
            
            const response = await channel.sendMessage(payload);
            return this._mapMessage(response.message, channel);
        } catch (error) {
            console.error("StreamBridge: Error sending message:", error);
            return null;
        }
    },

    /**
     * Uploads an image and sends a message with it attached
     */
    sendImageMessage: async function(channelId, text, file) {
        if (!this.client || !file) return null;
        try {
            const channel = this.client.channel('messaging', channelId);
            const response = await channel.sendImage(file);
            const imageUrl = response.file;
            
            const msgResponse = await channel.sendMessage({
                text: text || '',
                attachments: [{
                    type: 'image',
                    image_url: imageUrl,
                    fallback: file.name
                }]
            });
            return this._mapMessage(msgResponse.message, channel);
        } catch(error) {
            console.error("StreamBridge: Error sending image message:", error);
            return null;
        }
    },

    /**
     * Uploads a file (PDF, doc, etc.) and sends a message with it attached
     */
    sendFileMessage: async function(channelId, text, file) {
        if (!this.client || !file) return null;
        try {
            const channel = this.client.channel('messaging', channelId);
            const response = await channel.sendFile(file);
            const fileUrl = response.file;
            
            const msgResponse = await channel.sendMessage({
                text: text || '',
                attachments: [{
                    type: 'file',
                    asset_url: fileUrl,
                    title: file.name,
                    file_size: file.size,
                    mime_type: file.type || 'application/octet-stream'
                }]
            });
            return this._mapMessage(msgResponse.message, channel);
        } catch(error) {
            console.error("StreamBridge: Error sending file message:", error);
            return null;
        }
    },

    /**
     * Sends a reply to a specific message (threaded reply with quote)
     */
    sendReply: async function(channelId, parentMessageId, text) {
        if (!this.client) return null;
        try {
            const channel = this.client.channel('messaging', channelId);
            const mentionedUsers = this._extractMentions(text, channel);

            const payload = {
                text,
                parent_id: parentMessageId, 
                show_in_channel: true,
                quoted_message_id: parentMessageId
            };
            if (mentionedUsers.length > 0) {
                payload.mentioned_users = mentionedUsers;
            }

            const response = await channel.sendMessage(payload);
            return this._mapMessage(response.message, channel);
        } catch (error) {
            console.error("StreamBridge: Error sending reply:", error);
            return null;
        }
    },

    /**
     * Gets thread replies for a parent message
     */
    getThreadReplies: async function(channelId, parentMessageId) {
        if (!this.client) return [];
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.watch();
            const response = await channel.getReplies(parentMessageId, { limit: 50 });
            return (response.messages || []).map(m => this._mapMessage(m, channel));
        } catch (error) {
            console.error("StreamBridge: Error getting thread replies:", error);
            return [];
        }
    },

    /**
     * Deletes a message
     */
    deleteMessage: async function(messageId) {
        if (!this.client) return false;
        try {
            await this.client.deleteMessage(messageId);
            return true;
        } catch (error) {
            console.error("StreamBridge: Error deleting message:", error);
            return false;
        }
    },

    /**
     * Edits an existing message's text, preserving attachments
     */
    editMessage: async function(messageId, newText) {
        if (!this.client) return false;
        try {
            // Find existing message to preserve its attachments
            var existingAttachments = [];
            if (this.currentChannel && this.currentChannel.state && this.currentChannel.state.messages) {
                var existing = this.currentChannel.state.messages.find(m => m.id === messageId);
                if (existing && existing.attachments) {
                    existingAttachments = existing.attachments;
                }
            }
            await this.client.updateMessage({
                id: messageId,
                text: newText,
                attachments: existingAttachments
            });
            return true;
        } catch (error) {
            console.error("StreamBridge: Error editing message:", error);
            return false;
        }
    },

    /**
     * Checks if the current user is an admin
     */
    isAdmin: function() {
        if (!this.client || !this.client.user) return false;
        return this.client.user.role === 'admin';
    },

    /**
     * Adds a reaction to a message
     */
    addReaction: async function(messageId, reactionType) {
        if (!this.currentChannel) {
            console.error("StreamBridge: addReaction - no currentChannel set!");
            return false;
        }
        try {
            console.log("StreamBridge: Adding reaction", reactionType, "to message", messageId);
            console.log("StreamBridge: currentChannel.id =", this.currentChannel.id);
            const response = await this.currentChannel.sendReaction(messageId, { type: reactionType });
            console.log("StreamBridge: sendReaction response:", JSON.stringify(response?.reaction));
            
            // Check if the message in channel state has the reaction now
            const msg = this.currentChannel.state.messages.find(m => m.id === messageId);
            if (msg) {
                console.log("StreamBridge: After reaction - message reaction_counts:", 
                    JSON.stringify(msg.reaction_counts),
                    "own_reactions:", msg.own_reactions?.map(r => r.type));
            } else {
                console.warn("StreamBridge: Message", messageId, "not found in channel state!");
            }
            
            return true;
        } catch (error) {
            console.error("StreamBridge: Error adding reaction:", error);
            return false;
        }
    },

    /**
     * Removes a reaction from a message
     */
    removeReaction: async function(messageId, reactionType) {
        if (!this.currentChannel) return false;
        try {
            await this.currentChannel.deleteReaction(messageId, reactionType);
            return true;
        } catch (error) {
            console.error("StreamBridge: Error removing reaction:", error);
            return false;
        }
    },

    /**
     * Notify that the user has started typing
     */
    startTyping: async function(channelId) {
        if (!this.client) return false;
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.keystroke();
            return true;
        } catch (error) {
            console.error("StreamBridge: Error sending typing start:", error);
            return false;
        }
    },

    /**
     * Notify that the user has stopped typing
     */
    stopTyping: async function(channelId) {
        if (!this.client) return false;
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.stopTyping();
            return true;
        } catch (error) {
            console.error("StreamBridge: Error sending typing stop:", error);
            return false;
        }
    },

    /**
     * Mark a channel as read
     */
    markRead: async function(channelId) {
        if (!this.client) return false;
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.markRead();
            return true;
        } catch (error) {
            console.error("StreamBridge: Error marking read:", error);
            return false;
        }
    },

    /**
     * Register a callback for real-time events
     */
    onMessageNew: function(callback) {
        this.messageCallbacks.push(callback);
    },

    /**
     * Ensures the current user is a member of the global community channel
     */
    joinCommunityChannel: async function() {
        if (!this.client) return null;
        try {
            const channel = this.client.channel('messaging', 'wdw-community');
            await channel.watch();
            return this._mapChannelData(channel);
        } catch (error) {
            console.error("StreamBridge: Error joining community channel:", error);
            return null;
        }
    },

    /**
     * Search for users matching a query string
     */
    searchUsers: async function(query) {
        if (!this.client) return [];
        try {
            if (!query || query.trim() === '') {
                return await this.queryAllUsers();
            }
            const filter = {
                id: { $ne: this.client.userID },
                name: { $autocomplete: query }
            };
            const response = await this.client.queryUsers(filter, { name: 1 }, { limit: 20 });
            return response.users.map(u => ({
                id: u.id,
                name: u.name || u.id,
                image: u.image || ''
            }));
        } catch (error) {
            console.error("StreamBridge: Error searching users:", error);
            return [];
        }
    },

    /**
     * Query users by a list of Stream user IDs
     */
    queryUsersByIds: async function(userIdsCsv) {
        if (!this.client || !userIdsCsv) return [];
        try {
            const userIds = userIdsCsv.split(',').filter(id => id.trim());
            if (userIds.length === 0) return [];
            const filter = { id: { $in: userIds } };
            const response = await this.client.queryUsers(
                filter, { name: 1 }, { limit: userIds.length }
            );
            return response.users.map(u => ({
                id: u.id,
                name: u.name || u.id,
                image: u.image || ''
            }));
        } catch (error) {
            console.error("StreamBridge: Error querying users by IDs:", error);
            return [];
        }
    },

    /**
     * Query all community members (up to limit)
     */
    queryAllUsers: async function() {
        if (!this.client) return [];
        try {
            const filter = {
                id: { $ne: this.client.userID }
            };
            // limit to 100 for now, could be paginated later
            const response = await this.client.queryUsers(filter, { name: 1 }, { limit: 100 });
            return response.users.map(u => ({
                id: u.id,
                name: u.name || u.id,
                image: u.image || ''
            }));
        } catch (error) {
            console.error("StreamBridge: Error querying all users:", error);
            return [];
        }
    },

    /**
     * Creates or retrieves a 1-on-1 direct messaging channel
     */
    createDirectChannel: async function(otherUserId) {
        if (!this.client) return null;
        try {
            const channel = this.client.channel('messaging', {
                members: [this.client.userID, otherUserId]
            });
            await channel.watch();
            return this._mapChannelData(channel);
        } catch (error) {
            console.error("StreamBridge: Error creating direct channel:", error);
            return null;
        }
    },

    /**
     * Flags a message for moderation
     */
    flagMessage: async function(messageId) {
        if (!this.client) return false;
        try {
            await this.client.flagMessage(messageId);
            return true;
        } catch (error) {
            console.error("StreamBridge: Error flagging message:", error);
            return false;
        }
    },

    /**
     * Pins a message in a channel
     */
    pinMessage: async function(messageId) {
        if (!this.client) return false;
        try {
            await this.client.pinMessage({ id: messageId });
            return true;
        } catch (error) {
            console.error("StreamBridge: Error pinning message:", error);
            return false;
        }
    },

    /**
     * Unpins a message
     */
    unpinMessage: async function(messageId) {
        if (!this.client) return false;
        try {
            await this.client.unpinMessage({ id: messageId });
            return true;
        } catch (error) {
            console.error("StreamBridge: Error unpinning message:", error);
            return false;
        }
    },

    /**
     * Gets all pinned messages in a channel
     */
    getPinnedMessages: async function(channelId) {
        if (!this.client) return [];
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.watch();
            const pinned = channel.state.pinnedMessages || [];
            return pinned.map(m => this._mapMessage(m, channel));
        } catch (error) {
            console.error("StreamBridge: Error getting pinned messages:", error);
            return [];
        }
    },

    /**
     * Sends a message with a GIF attachment
     */
    sendGiphyMessage: async function(channelId, gifUrl, gifTitle) {
        if (!this.client) return null;
        try {
            const channel = this.client.channel('messaging', channelId);
            const msgResponse = await channel.sendMessage({
                text: '',
                attachments: [{
                    type: 'giphy',
                    image_url: gifUrl,
                    thumb_url: gifUrl,
                    title: gifTitle || 'GIF',
                    title_link: gifUrl,
                    giphy: { original: { url: gifUrl } }
                }]
            });
            return this._mapMessage(msgResponse.message, channel);
        } catch (error) {
            console.error("StreamBridge: Error sending GIF message:", error);
            return null;
        }
    },

    /**
     * Gets the members of a channel
     */
    getChannelMembers: async function(channelId) {
        if (!this.client) return [];
        try {
            const channel = this.client.channel('messaging', channelId);
            await channel.watch();
            const members = Object.values(channel.state.members || {});
            return members.map(m => ({
                userId: m.user?.id || '',
                userName: m.user?.name || m.user?.id || '',
                userImage: m.user?.image || '',
                role: m.role || 'member',
                online: m.user?.online || false,
                lastActive: m.user?.last_active ? new Date(m.user.last_active).toISOString() : ''
            }));
        } catch (error) {
            console.error("StreamBridge: Error getting channel members:", error);
            return [];
        }
    },

    /**
     * Registers a device token for push notifications
     */
    addDevice: async function(token, pushProvider = 'firebase', pushProviderName = 'wdw') {
        if (!this.client) return false;
        try {
            await this.client.addDevice(token, pushProvider, this.client.userID, pushProviderName);
            console.log(`StreamBridge: Registered device for pushes (${pushProvider}/${pushProviderName})`);
            return true;
        } catch (error) {
            console.error("StreamBridge: Error registering device token:", error);
            return false;
        }
    },

    /**
     * Unregisters a device token to disable push notifications
     */
    removeDevice: async function(token) {
        if (!this.client) return false;
        try {
            await this.client.removeDevice(token, this.client.userID);
            console.log("StreamBridge: Unregistered device for pushes");
            return true;
        } catch (error) {
            console.error("StreamBridge: Error removing device token:", error);
            return false;
        }
    },

    /**
     * Disconnects the current user
     */
    disconnectUser: async function() {
        console.log("StreamBridge: disconnectUser called");
        try {
            if (this.client) {
                await this.client.disconnectUser();
                this.client = null;
                this.initialized = false;
                this.messageCallbacks = [];
                console.log("StreamBridge: User disconnected");
            }
        } catch (error) {
            console.error("StreamBridge: Error in disconnectUser:", error);
        }
    }
};

console.log("StreamBridge: wdwStreamBridge defined on window");

// Drag & Drop file helper
window._dragDrop = { isDragging: false, droppedFile: null };
window.setupDragDrop = function() {
    document.body.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.stopPropagation();
        window._dragDrop.isDragging = true;
    });
    document.body.addEventListener('dragleave', function(e) {
        e.preventDefault();
        e.stopPropagation();
        window._dragDrop.isDragging = false;
    });
    document.body.addEventListener('drop', function(e) {
        e.preventDefault();
        e.stopPropagation();
        window._dragDrop.isDragging = false;
        if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files.length > 0) {
            window._dragDrop.droppedFile = e.dataTransfer.files[0];
        }
    });
    console.log("DragDrop: handlers installed");
};
window.isDraggingOver = function() { return window._dragDrop.isDragging; };
window.getDroppedFile = function() {
    var f = window._dragDrop.droppedFile;
    window._dragDrop.droppedFile = null;
    return f;
};
